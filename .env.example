# Copy to `.env` and adjust. Only EXPO_PUBLIC_* vars are exposed to the app bundle.

# Base URL of the versioned REST API (includes /api/v1).
# On a physical device over Expo Go, replace `localhost` with your computer's LAN IP,
# e.g. http://192.168.1.5:4000/api/v1  — the phone can't reach the laptop's localhost.
EXPO_PUBLIC_API_URL=http://localhost:4000/api/v1
